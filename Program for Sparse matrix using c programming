#include <stdio.h>
int main() {
int matrix[10][10], sparse[20][3];
int i, j, m, n, k = 1;
printf("Enter rows and columns: ");
scanf("%d %d", &m, &n);
printf("Enter matrix elements:\n");
for(i = 0; i < m; i++) 
for(j = 0; j < n; j++) {
scanf("%d", &matrix[i][j]);
        }
    }
int count = 0;
for(i = 0; i < m; i++) {
for(j = 0; j < n; j++) {
if(matrix[i][j] != 0) {
count++;
            }
        }
    }
sparse[0][0] = m;
sparse[0][1] = n;
sparse[0][2] = count;
for(i = 0; i < m; i++) {
for(j = 0; j < n; j++) {
if(matrix[i][j] != 0) {
sparse[k][0] = i;
sparse[k][1] = j;
sparse[k][2] = matrix[i][j];
k++;
            }
        }
    }
printf("Sparse Matrix Representation:\n");
printf("Row Col Value\n");
for(i = 0; i <= count; i++) {
printf("%d   %d   %d\n", sparse[i][0], sparse[i][1], sparse[i][2]);
    }
} 
